# このファイルをコピーして secrets.toml にリネームして使ってください
# secrets.toml は .gitignore に含まれているので Git には上がりません

API_KEY = "your-api-key"

# 旅行プラン自動作成アプリ用
# Gemini API キー（取得済みのキーをここに記入）
GEMINI_API_KEY = "your-gemini-api-key"

# Google Maps API キー（未取得なら空文字のままでOK。
# 未設定の間は移動時間・営業時間はダミー値で動作します）
GOOGLE_MAPS_API_KEY = ""

# Turso（クラウドDB）用。未設定の場合は data/app.db（ローカルファイル）が使われ、
# チーム間でデータは共有されません。
# チームで「みんなのプラン」を共有したい場合は、Turso CLIで作成したDBの
# URLとトークンをここに記入してください。
TURSO_DATABASE_URL = ""
TURSO_AUTH_TOKEN = ""
